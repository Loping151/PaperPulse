[Unit]
Description=Paper Pulse Web UI
After=network.target

[Service]
Type=simple
# TODO: change to your actual project path
WorkingDirectory=/opt/paper-pulse
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/opt/paper-pulse/.env
ExecStart=/usr/bin/python3 -m uvicorn webapp:app --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
