# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ===========================================
# 轻量级 LLM 配置 (用于论文筛选)
# ===========================================
LIGHT_LLM_API_BASE=https://api.example.com/v1
LIGHT_LLM_API_KEY=your-light-llm-api-key
LIGHT_LLM_MODEL=gemini-3-flash

# ===========================================
# 重量级多模态 LLM 配置 (用于 PDF 分析)
# ===========================================
HEAVY_LLM_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
HEAVY_LLM_API_KEY=your-gemini-api-key
HEAVY_LLM_MODEL=gemini-3.1-pro

# ===========================================
# 邮件通知配置 (二选一即可)
# ===========================================
# --- Email Proxy 模式 ---
EMAIL_PROXY_API_URL=https://your-email-proxy.example.com
EMAIL_PROXY_API_TOKEN=your-email-proxy-token

# --- SMTP 直接发送模式 ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password

# ===========================================
# 可选配置
# ===========================================
# TZ=Asia/Shanghai

# ===========================================
# EZproxy / 机构代理配置 (用于访问付费期刊 PDF)
# ===========================================
EZPROXY_BASE_URL=https://eproxy.lib.your-school.edu/login?url=
EZPROXY_UID=your-library-uid
EZPROXY_PIN=your-library-pin
# 可选：如果你的学校登录表单字段名不同，可修改以下默认值
# EZPROXY_USERNAME_FIELD=userid
# EZPROXY_PASSWORD_FIELD=password
# EZPROXY_SUBMIT_SELECTOR=input[type='submit']
